{
	# Use only the TLS-ALPN-01 challenge (over 443); never rely on port 80.
	auto_https disable_redirects
}

calc.cloudyhome.org {
	tls {
		issuer acme {
			disable_http_challenge
		}
	}
	reverse_proxy calculators:8080
}

# Per-app routes generated by the application role. Each routed app drops its own
# <name>.caddy snippet here, so adding a routed app needs no edit to this file.
import /etc/caddy/conf.d/*.caddy
