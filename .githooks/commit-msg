#!/bin/sh
#
# commit-msg hook — enforce the repository's commit-message conventions:
#   * Conventional Commits subject: "<type>[(scope)][!]: <description>"
#   * subject no longer than 100 characters
#   * no Co-Authored-By trailers
#
# Enabled via:  git config core.hooksPath .githooks
# See CODING_CONVENTIONS.md ("Git").

message_file="$1"

# First non-blank, non-comment line is the subject.
subject=$(grep -vE '^[[:space:]]*#' "$message_file" | sed '/^[[:space:]]*$/d' | head -n 1)

# Let Git's own auto-generated merge/revert messages through unchanged.
case "$subject" in
    "Merge "* | "Revert "* | "fixup!"* | "squash!"*)
        exit 0
        ;;
esac

allowed_types='feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert'

fail() {
    echo "✖ commit-msg: $1" >&2
    exit 1
}

if ! printf '%s' "$subject" | grep -qE "^(${allowed_types})(\([a-z0-9._/-]+\))?!?: .+"; then
    echo "✖ commit-msg: subject must follow Conventional Commits." >&2
    echo "    format: <type>[(scope)][!]: <description>" >&2
    echo "    types:  feat fix docs style refactor perf test build ci chore revert" >&2
    echo "    got:    \"$subject\"" >&2
    exit 1
fi

subject_length=$(printf '%s' "$subject" | wc -c | tr -d ' ')
if [ "$subject_length" -gt 100 ]; then
    fail "subject is $subject_length characters; keep it within 100."
fi

if grep -qiE '^[[:space:]]*Co-Authored-By:' "$message_file"; then
    fail "remove the Co-Authored-By trailer."
fi

exit 0
